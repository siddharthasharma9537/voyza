# ══════════════════════════════════════════════════════════════════════════════
# VOYZA ENVIRONMENT CONFIGURATION
# ══════════════════════════════════════════════════════════════════════════════
# Copy this file to .env and update with your values

# ── Database Configuration ─────────────────────────────────────────────────────
DB_USER=voyza
DB_PASSWORD=change_me_to_secure_password
DB_NAME=voyza_db
DB_PORT=5432

# ── MinIO/S3 Configuration ─────────────────────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change_me_to_secure_password
AWS_S3_BUCKET_NAME=voyza-documents
AWS_REGION=us-east-1
MINIO_PORT=9000
MINIO_DOMAIN=minio.voyzacar.online

# For production S3 (AWS) instead of MinIO:
# AWS_S3_ENDPOINT=https://s3.amazonaws.com
# AWS_ACCESS_KEY_ID=your_aws_access_key
# AWS_SECRET_ACCESS_KEY=your_aws_secret_key

# For local development with MinIO:
AWS_S3_ENDPOINT=http://minio:9000

# ── Redis Configuration ────────────────────────────────────────────────────────
REDIS_PASSWORD=change_me_to_secure_password
REDIS_URL=redis://:change_me_to_secure_password@redis:6379

# ── Backend API Configuration ──────────────────────────────────────────────────
SECRET_KEY=change_me_to_very_long_random_secure_key_min_32_chars
DEBUG=false
API_PORT=8000

# ── Frontend Configuration ─────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://api.voyzacar.online/api/v1
NODE_ENV=production

# For development:
# NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
# NODE_ENV=development

# ── Domain & CORS Configuration ────────────────────────────────────────────────
DOMAIN_NAME=voyzacar.online
CORS_ORIGINS=https://voyzacar.online,https://www.voyzacar.online,https://api.voyzacar.online

# For development:
# CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# ── SSL Certificate Configuration ──────────────────────────────────────────────
SSL_CERT_PATH=/etc/letsencrypt/live/voyzacar.online/fullchain.pem
SSL_KEY_PATH=/etc/letsencrypt/live/voyzacar.online/privkey.pem

# ── Email Configuration (Optional) ─────────────────────────────────────────────
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM=noreply@voyzacar.online

# ── SMS Configuration (Optional - Twilio) ──────────────────────────────────────
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# ── Payment Gateway (Optional) ─────────────────────────────────────────────────
RAZORPAY_KEY_ID=your_razorpay_key
RAZORPAY_KEY_SECRET=your_razorpay_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# ── Logging & Monitoring ──────────────────────────────────────────────────────
LOG_LEVEL=info
SENTRY_DSN=

# ── Database Backup Configuration ──────────────────────────────────────────────
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *  # Daily at 2 AM UTC

# ── Development/Testing ────────────────────────────────────────────────────────
# Set to 'true' only in development
ALLOW_TESTING_ENDPOINTS=false
